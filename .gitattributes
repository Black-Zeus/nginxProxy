# Normalizar todos los archivos de texto a LF en repo y working directory
* text=auto eol=lf

# Configuración y contenedores
/.gitattributes text eol=lf
/.gitignore text eol=lf
*.sh text eol=lf
*.bash text eol=lf
Dockerfile* text eol=lf
*.conf text eol=lf
*.env text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.svg text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.xml text eol=lf

# Binarios — sin conversión
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
